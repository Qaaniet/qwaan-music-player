{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qwaan-music-player",
  "version": "0.1.0",
  "identifier": "com.qaani.qwaan-music-player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "qwaan-music-player",
        "decorations": false,
        "minWidth": 1024,
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$LOCALDATA/QwaanMusicPlayer/artwork/**",
          "$LOCALDATA/QwaanMusicPlayer/artist-images/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
